{"pair_key": "tu_1", "zh_text": "在首层放置安全护栏。", "en_text": "Lay out the safety guard fence at the home landing.", "metadata": {"source_type": "tmx", "source_path": "C:\\Users\\30056638\\PycharmProjects\\PythonProject_translateagent\\tmx\\561.tmx", "source_file": "561.tmx", "tu_index": 1, "cn_empty": false, "en_empty": false, "missing": ""}}
